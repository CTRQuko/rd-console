# Never ship the staging imports, venvs, node_modules, or local artefacts.
.git/
.gitignore
.github/
.vscode/
.idea/
.venv/
backend/.venv/
backend/**/__pycache__/
backend/*.egg-info/
backend/.pytest_cache/
backend/.ruff_cache/
backend/rd_console.sqlite3
backend/rd_console.sqlite3-journal
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
_design-import/
_design-import-fixes/
LOGS/
*.log
*.sqlite3
*.sqlite3-journal

# Env files — NEVER bake secrets into the image.
.env
.env.local
.env.*.local

# Bundle staging folders that land in Downloads/.
rd-console\ Design\ System\ FIXES.zip

# Docs + planning artefacts don't need to be in the image.
PLANES/
README.md
docs/
