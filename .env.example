# rd-console — environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# ───────────── Environment ─────────────
# dev (default) | prod
# prod enforces strict validation on RD_SECRET_KEY (>= 32 chars, not the default)
# and logs warnings if client-facing endpoints are left open.
RD_ENVIRONMENT=dev

# ───────────── RustDesk server ─────────────
# Hostname clients use for ID/relay (points to hbbs/hbbr)
RD_SERVER_HOST=
# Public URL of the admin panel (HTTPS recommended)
RD_PANEL_URL=
# Contents of /opt/rustdesk/data/id_ed25519.pub on the hbbs host
RD_HBBS_PUBLIC_KEY=

# ───────────── Backend ─────────────
# 32+ random chars — used to sign JWTs. Generate with: openssl rand -hex 32
# Required in production; must not be the shipping default value.
RD_SECRET_KEY=
# SQLite DB path inside the container
RD_DB_PATH=/data/rd_console.sqlite3
# HTTP port the FastAPI app binds to
PORT=8080

# ───────────── RustDesk client protocol hardening ─────────────
# Optional shared secret. When set, /api/heartbeat, /api/sysinfo and /api/audit/*
# require the X-RD-Secret header to match. Leave empty to keep endpoints open
# (backward compatible; a startup warning is logged in prod).
RD_CLIENT_SHARED_SECRET=
# Hard cap (bytes) on AuditLog.payload persistence from client events.
# Prevents a malicious client from filling the database.
RD_MAX_AUDIT_PAYLOAD_BYTES=4096

# ───────────── Bootstrap admin ─────────────
# Created on first start if no admin exists. Password is hashed with argon2id.
# Ignored if an admin already exists.
RD_ADMIN_USERNAME=admin
RD_ADMIN_PASSWORD=
